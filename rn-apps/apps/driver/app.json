{
  "expo": {
    "name": "EntregaPRO - Motorista",
    "slug": "entregapro-driver",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#4F46E5",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entregapro.driver",
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5"
      },
      "package": "com.entregapro.driver",
      "versionCode": 2
    },
    "extra": {
      "environment": "development",
      "eas": {
        "projectId": "9e44ed3a-5b3e-4763-b4ef-81d8a210669a"
      }
    },
    "plugins": [
      "expo-location",
      "expo-camera",
      "expo-secure-store"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
