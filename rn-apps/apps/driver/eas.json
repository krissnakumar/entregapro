{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "local": {
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true
      }
    },
    "development": {
      "node": "22.13.0",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "node": "22.13.0",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "node": "22.13.0",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
