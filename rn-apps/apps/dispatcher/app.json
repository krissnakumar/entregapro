{
  "expo": {
    "name": "EntregaPRO - Despachante",
    "slug": "entregapro-dispatcher",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entregapro.dispatcher",
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "permissions": ["POST_NOTIFICATIONS"],
      "package": "com.entregapro.dispatcher",
      "versionCode": 2
    },
    "extra": {
      "environment": "development",
      "eas": {
        "projectId": "263e7d1d-6ff3-4591-b5e3-9da2cbd23efc"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
