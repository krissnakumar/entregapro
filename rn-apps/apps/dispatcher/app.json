{
  "expo": {
    "name": "EntregaPRO - Despachante",
    "slug": "entregapro-dispatcher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entregapro.dispatcher"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.entregapro.dispatcher"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
