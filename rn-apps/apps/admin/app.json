{
  "expo": {
    "name": "EntregaPRO - Admin",
    "slug": "entregapro-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#4F46E5",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entregapro.admin",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5"
      },
      "package": "com.entregapro.admin",
      "versionCode": 1
    },
    "extra": {
      "environment": "development",
      "eas": {
        "projectId": "d3f8b9fc-5582-4ba1-91ea-e18d00df7cac"
      }
    },
    "plugins": [
      "expo-secure-store"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
