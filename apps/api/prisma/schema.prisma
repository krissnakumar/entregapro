generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

enum OrderStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  PICKING_UP
  LOADED
  IN_TRANSIT
  ARRIVED
  DELIVERED
  FAILED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  AUTHORIZED
  CANCELLED
  DENIED
  PROCESSED
  ERROR
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum DeliveryStatus {
  CREATED
  PENDING_DISPATCH
  ASSIGNED
  DRIVER_NOTIFIED
  ACCEPTED_BY_DRIVER
  LOADING_STARTED
  LOADED
  IN_TRANSIT
  ARRIVED
  DELIVERED
  PARTIALLY_DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum LoadingStatus {
  NOT_LOADED
  LOADING
  LOADED
  LOAD_ISSUE
}

enum FuelRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum DeliveryEventType {
  STATUS_CHANGE
  LOADING
  PROBLEM
  NOTE
  FUEL
  POD
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  document  String?
  phone     String?
  email     String?
  address   String?
  city      String?
  state     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users                         User[]
  roles                         Role[]
  customers                     Customer[]
  vehicles                      Vehicle[]
  drivers                       Driver[]
  orders                        Order[]
  deliveries                    Delivery[]
  notifications                 Notification[]
  zones                         Zone[]
  activityLogs                  ActivityLog[]
  auditLogEntries               AuditLogEntry[]
  geofences                     Geofence[]
  locationPings                 LocationPing[]
  whatsappMessages              WhatsappMessage[]
  invoices                      Invoice[]
  fuelLogs                      FuelLog[]
  maintenanceLogs               MaintenanceLog[]
  loadingVerifications          LoadingVerification[]
  analyticsSnapshots            AnalyticsSnapshot[]
  systemSettings                SystemSetting[]
  subscription                  Subscription?
  jobSites                      JobSite[]
  routes                        Route[]
  routeStops                    RouteStop[]
  driverShifts                  DriverShift[]
  driverPerformances            DriverPerformance[]
  customerDeliveryPreferences   CustomerDeliveryPreference[]
  deliveryExceptions            DeliveryException[]
  routeCosts                    RouteCost[]
  dispatchDecisions             DispatchDecision[]
  assignmentRecommendations     AssignmentRecommendation[]
  vehicleCapacities             VehicleCapacity[]
  deliveryTrackingTokens        DeliveryTrackingToken[]
  deliveryEvents                DeliveryEvent[]
  deliveryVoiceNotes            DeliveryVoiceNote[]
  deliveryInstructions          DeliveryInstruction[]
  deliveryAvailabilityResponses DeliveryAvailabilityResponse[]
  proofsOfDelivery              ProofOfDelivery[]
  routeClusters                 RouteCluster[]
  driverWorkloadMetrics         DriverWorkloadMetric[]
  loadBatches                   LoadBatch[]
  deliveryItems                 DeliveryItem[]
  deliveryTimelines             DeliveryTimeline[]
  fuelRequests                  FuelRequest[]
  products                      Product[]
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  phone          String?
  avatarUrl      String?
  refreshToken   String?
  updatedAt      DateTime  @updatedAt
  active_status  Boolean   @default(true)
  created_at     DateTime  @default(now())
  last_login     DateTime?
  password_hash  String
  role_id        String?
  organizationId String
  deletedAt      DateTime?
  createdBy      String?

  organization             Organization          @relation(fields: [organizationId], references: [id])
  role                     Role?                 @relation(fields: [role_id], references: [id])
  activityLogs             ActivityLog[]
  dispatchedDeliveries     Delivery[]            @relation("DispatcherDeliveries")
  statusChanges            DeliveryStatusLog[]   @relation("StatusChanges")
  driverProfile            Driver?
  notifications            Notification[]
  dispatchedOrders         Order[]               @relation("DispatcherOrders")
  auditLogs                AuditLogEntry[]
  loadingVerifications     LoadingVerification[]
  dispatchDecisions        DispatchDecision[]
  approvedFuelLogs         FuelLog[]             @relation("FuelLogApprover")
  createdDeliveriesByAdmin Delivery[]            @relation("DeliveryCreator")
  approvedFuelRequests     FuelRequest[]         @relation("FuelRequestApprover")
  dispatchedFuelRequests   FuelRequest[]         @relation("FuelRequestDispatcher")
  loadBatches              LoadBatch[]           @relation("LoadBatchDispatcher")
  pushTokens               PushToken[]

  @@index([organizationId])
  @@index([email])
}

model Role {
  id             String    @id @default(uuid())
  name           String
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  deletedAt      DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id])
  permissions  RolePermission[]
  users        User[]

  @@unique([name, organizationId])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  permission_id String
  role_id       String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model Customer {
  id             String    @id @default(uuid())
  name           String
  email          String?
  phone          String
  whatsapp       String?
  address        String
  latitude       Float
  longitude      Float
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  deletedAt      DateTime?
  createdBy      String?

  organization        Organization                 @relation(fields: [organizationId], references: [id])
  deliveries          Delivery[]
  deliveryPreferences CustomerDeliveryPreference[]

  @@index([organizationId])
  @@index([phone])
}

model Vehicle {
  id             String    @id @default(uuid())
  vehicleNumber  String    @unique
  type           String
  capacity       String
  fuelType       String
  activeStatus   Boolean   @default(true)
  maintenanceDue DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  deletedAt      DateTime?
  createdBy      String?

  organization      Organization      @relation(fields: [organizationId], references: [id])
  deliveries        Delivery[]
  driver            Driver?
  fuelLogs          FuelLog[]
  maintenanceLogs   MaintenanceLog[]
  routes            Route[]
  vehicleCapacities VehicleCapacity[]
  fuelRequests      FuelRequest[]
  loadBatches       LoadBatch[]

  @@index([organizationId])
  @@index([vehicleNumber])
}

model Driver {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId          String?   @unique
  vehicle            Vehicle?  @relation(fields: [vehicleId], references: [id])
  licenseNumber      String    @unique
  phone              String
  liveLatitude       Float?
  liveLongitude      Float?
  availabilityStatus Boolean   @default(true)
  isOnline           Boolean   @default(false)
  lastSeen           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  organizationId     String
  deletedAt          DateTime?
  createdBy          String?

  organization      Organization           @relation(fields: [organizationId], references: [id])
  deliveries        Delivery[]             @relation("MainDriver")
  helperFor         Delivery[]             @relation("HelperCrew")
  fuelLogs          FuelLog[]
  routes            Route[]
  driverShifts      DriverShift[]
  driverPerformance DriverPerformance?
  voiceNotes        DeliveryVoiceNote[]
  workloadMetrics   DriverWorkloadMetric[]
  fuelRequests      FuelRequest[]
  loadBatches       LoadBatch[]

  @@index([organizationId])
  @@index([availabilityStatus])
}

model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique
  dispatcherId   String?
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organizationId String
  deletedAt      DateTime?
  createdBy      String?

  organization Organization @relation(fields: [organizationId], references: [id])
  deliveries   Delivery[]
  dispatcher   User?        @relation("DispatcherOrders", fields: [dispatcherId], references: [id])

  @@index([organizationId])
  @@index([status])
}

model Delivery {
  id               String   @id @default(uuid())
  deliveryNumber   String   @unique
  orderId          String?
  order            Order?   @relation(fields: [orderId], references: [id])
  driverId         String?
  driver           Driver?  @relation("MainDriver", fields: [driverId], references: [id])
  vehicleId        String?
  vehicle          Vehicle? @relation(fields: [vehicleId], references: [id])
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id])
  dispatcherId     String?
  dispatcher       User?    @relation("DispatcherDeliveries", fields: [dispatcherId], references: [id])
  createdByAdminId String?
  createdByAdmin   User?    @relation("DeliveryCreator", fields: [createdByAdminId], references: [id])

  materialType    String
  quantity        String
  deliveryAddress String
  latitude        Float
  longitude       Float
  scheduledTime   DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  status          OrderStatus    @default(PENDING)
  deliveryStatus  DeliveryStatus @default(CREATED)
  loadingStatus   LoadingStatus  @default(NOT_LOADED)

  eta_minutes        Int?
  route_distance     Float?
  loading_started_at DateTime?
  deliveryStartedAt  DateTime?
  deliveredAt        DateTime?
  failedAt           DateTime?
  failureReason      String?
  transit_started_at DateTime?

  proof_image_url String?
  signature_url   String?
  pod_latitude    Float?
  pod_longitude   Float?
  pod_timestamp   DateTime?

  helpers               Driver[]                       @relation("HelperCrew")
  statusLogs            DeliveryStatusLog[]
  tracking              DeliveryTracking[]
  invoices              Invoice[]
  loadingVerification   LoadingVerification?
  jobSiteId             String?
  jobSite               JobSite?                       @relation(fields: [jobSiteId], references: [id])
  trackingTokens        DeliveryTrackingToken[]
  events                DeliveryEvent[]
  voiceNotes            DeliveryVoiceNote[]
  instructions          DeliveryInstruction[]
  availabilityResponses DeliveryAvailabilityResponse[]
  proofOfDelivery       ProofOfDelivery?
  deliveryItems         DeliveryItem[]
  loadBatchDeliveries   LoadBatchDelivery[]
  timeline              DeliveryTimeline[]

  total_km                       Float?
  estimated_driving_time_minutes Int?
  toll_cost                      Float?
  traffic_delay_minutes          Int?
  expected_fuel_liters           Float?
  expected_fuel_cost             Float?
  driver_cost                    Float?
  assistant_cost                 Float?
  maintenance_cost               Float?
  estimated_profit               Float?
  delivery_margin_percentage     Float?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  deletedAt      DateTime?
  createdBy      String?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([deliveryStatus])
  @@index([driverId])
  @@index([organizationId, status])
  @@index([organizationId, deliveryStatus])
  @@index([organizationId, scheduledTime])
}

model DeliveryTracking {
  id           String   @id @default(uuid())
  deliveryId   String
  lat          Float
  lng          Float
  timestamp    DateTime @default(now())
  batteryLevel Float?
  heading      Float?
  speed        Float?
  delivery     Delivery @relation(fields: [deliveryId], references: [id])

  @@index([deliveryId])
  @@index([timestamp])
}

model DeliveryStatusLog {
  id         String      @id @default(uuid())
  deliveryId String
  status     OrderStatus
  changedAt  DateTime    @default(now())
  notes      String?
  changed_by String?
  changedBy  User?       @relation("StatusChanges", fields: [changed_by], references: [id])
  delivery   Delivery    @relation(fields: [deliveryId], references: [id])

  @@index([deliveryId])
  @@index([changedAt])
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  title          String
  message        String
  isRead         Boolean  @default(false)
  type           String?
  recipientRole  String?
  payload        Json?
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId, isRead])
  @@index([userId, type])
}

model Zone {
  id             String    @id @default(uuid())
  name           String
  description    String?
  color          String    @default("#3b82f6")
  polygon        Json
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ActivityLog {
  id             String   @id @default(uuid())
  userId         String?
  action         String
  entity         String
  entityId       String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([createdAt])
}

model AuditLogEntry {
  id             String   @id @default(uuid())
  userId         String?
  action         String
  entity         String
  entityId       String?
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([entity, entityId])
}

model JobSite {
  id             String    @id @default(uuid())
  name           String
  description    String?
  address        String?
  contactName    String?
  contactPhone   String?
  latitude       Float
  longitude      Float
  polygon        Json?     @default("null")
  radius         Float?    @default(50)
  color          String    @default("#8B5CF6")
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  deliveries   Delivery[]

  @@index([organizationId])
}

model Geofence {
  id             String    @id @default(uuid())
  name           String
  description    String?
  polygon        Json
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model LocationPing {
  id             String   @id @default(uuid())
  driverId       String
  lat            Float
  lng            Float
  speed          Float?
  heading        Float?
  batteryLevel   Float?
  timestamp      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([driverId, timestamp])
}

model WhatsappMessage {
  id             String   @id @default(uuid())
  deliveryId     String?
  phone          String
  message        String
  status         String
  providerRef    String?
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([deliveryId])
}

model Plan {
  id                    String   @id @default(uuid())
  name                  String   @unique
  slug                  String   @unique
  description           String?
  monthlyPrice          Float
  trialDays             Int      @default(7)
  maxDrivers            Int
  maxDispatchers        Int
  maxDeliveriesPerMonth Int
  maxVehicles           Int?
  maxCustomers          Int?
  hasRouteOptimization  Boolean  @default(false)
  hasLiveTracking       Boolean  @default(true)
  hasWhatsApp           Boolean  @default(false)
  hasCustomerPortal     Boolean  @default(false)
  hasAnalytics          Boolean  @default(true)
  hasConstructionModule Boolean  @default(false)
  isPopular             Boolean  @default(false)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(uuid())
  organizationId     String             @unique
  planId             String
  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  gracePeriodEndsAt  DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  plan           Plan            @relation(fields: [planId], references: [id])
  billingEvents  BillingEvent[]
  usageTrackings UsageTracking[]
}

model UsageTracking {
  id             String   @id @default(uuid())
  subscriptionId String
  metric         String
  count          Int      @default(0)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

model BillingEvent {
  id             String   @id @default(uuid())
  subscriptionId String
  eventType      String
  amount         Float
  currency       String   @default("BRL")
  description    String?
  status         String   @default("PENDING")
  gatewayRef     String?
  invoiceUrl     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String?
  vendorName    String?
  issueDate     DateTime?
  dueDate       DateTime?
  totalAmount   Float?
  currency      String        @default("BRL")
  status        InvoiceStatus @default(PENDING)
  fileUrl       String
  fileType      String
  extractedText String?       @db.Text

  // NF-e specific fields
  accessKey             String?   @unique
  nfeNumber             String?
  series                Int?
  cfop                  String?
  naturezaOperacao      String?
  icms                  Float?
  ipi                   Float?
  pis                   Float?
  cofins                Float?
  iss                   Float?
  totalTaxes            Float?
  xmlContent            String?   @db.Text
  xmlUrl                String?
  danfeUrl              String?
  authorizationProtocol String?
  authorizationDate     DateTime?
  cancellationProtocol  String?
  cancellationDate      DateTime?
  nfeStatus             String?   @default("PENDING")

  // Delivery logistics fields
  weight                     Float?
  volume                     Float?
  itemCount                  Int?
  fragile                    Boolean   @default(false)
  priority                   Int       @default(0)
  deliveryDeadline           DateTime?
  customerRequestedStartTime DateTime?
  customerRequestedEndTime   DateTime?
  unloadRequired             Boolean   @default(false)
  helperRequired             Boolean   @default(false)
  deliveryNotes              String?
  addressLat                 Float?
  addressLng                 Float?
  zoneId                     String?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  organizationId    String
  deletedAt         DateTime?
  createdBy         String?
  items             InvoiceItem[]
  deliveryId        String?
  delivery          Delivery?           @relation(fields: [deliveryId], references: [id])
  routeStops        RouteStop[]
  exceptions        DeliveryException[]
  dispatchDecisions DispatchDecision[]

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([deliveryId])
  @@index([status])
  @@index([zoneId])
  @@index([priority])
  @@index([weight])
}

model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float?
  unitPrice   Float?
  totalPrice  Float?

  // NF-e item fields
  ncm            String?
  cst            String?
  cfop           String?
  icmsAliquota   Float?
  icmsValor      Float?
  ipiAliquota    Float?
  ipiValor       Float?
  pisAliquota    Float?
  pisValor       Float?
  cofinsAliquota Float?
  cofinsValor    Float?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── Dispatch & Route Optimization Models ─────────────────────────────────

model Route {
  id                  String    @id @default(uuid())
  name                String?
  status              String    @default("SUGGESTED")
  driverId            String?
  driver              Driver?   @relation(fields: [driverId], references: [id])
  vehicleId           String?
  vehicle             Vehicle?  @relation(fields: [vehicleId], references: [id])
  totalDistance       Float?
  totalDuration       Int?
  totalCost           Float?
  totalWeight         Float?
  totalVolume         Float?
  stopCount           Int?
  capacityUtilization Float?
  riskScore           Float?
  optimizedAt         DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  organizationId      String
  deletedAt           DateTime?

  organization Organization               @relation(fields: [organizationId], references: [id])
  stops        RouteStop[]
  assignments  AssignmentRecommendation[]
  routeCosts   RouteCost[]
  voiceNotes   DeliveryVoiceNote[]

  @@index([organizationId])
  @@index([driverId])
  @@index([status])
}

model RouteStop {
  id                 String    @id @default(uuid())
  routeId            String
  route              Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  invoiceId          String
  invoice            Invoice   @relation(fields: [invoiceId], references: [id])
  stopSequence       Int
  estimatedArrival   DateTime?
  estimatedDeparture DateTime?
  actualArrival      DateTime?
  actualDeparture    DateTime?
  status             String    @default("PENDING")
  notes              String?
  createdAt          DateTime  @default(now())
  organizationId     String

  organization Organization        @relation(fields: [organizationId], references: [id])
  voiceNotes   DeliveryVoiceNote[]

  @@index([routeId])
  @@index([invoiceId])
  @@index([organizationId])
}

model DriverShift {
  id             String   @id @default(uuid())
  driverId       String
  driver         Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startTime      String
  endTime        String
  isAvailable    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([driverId])
  @@index([organizationId])
}

model DriverPerformance {
  id                  String   @id @default(uuid())
  driverId            String   @unique
  driver              Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  onTimeRate          Float    @default(1.0)
  failedDeliveryRate  Float    @default(0.0)
  averageRating       Float    @default(5.0)
  totalDeliveries     Int      @default(0)
  completedDeliveries Int      @default(0)
  failedDeliveries    Int      @default(0)
  score               Float    @default(5.0)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
  organizationId      String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([driverId])
  @@index([organizationId])
}

model CustomerDeliveryPreference {
  id                 String   @id @default(uuid())
  customerId         String
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  preferredTimeStart String?
  preferredTimeEnd   String?
  avoidLunch         Boolean  @default(false)
  callBeforeDelivery Boolean  @default(false)
  needsHelper        Boolean  @default(false)
  needsUnloading     Boolean  @default(false)
  accessRestriction  String?
  buildingRules      String?
  gateInstruction    String?
  contactPreference  String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  organizationId     String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([customerId])
  @@index([organizationId])
}

model DeliveryException {
  id             String    @id @default(uuid())
  invoiceId      String
  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type           String
  reason         String?
  description    String?
  resolvedAt     DateTime?
  resolvedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([invoiceId])
  @@index([organizationId])
  @@index([type])
}

model RouteCost {
  id              String   @id @default(uuid())
  routeId         String
  route           Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  fuelCost        Float?
  tollCost        Float?
  driverCost      Float?
  maintenanceCost Float?
  totalCost       Float?
  estimatedAt     DateTime @default(now())
  organizationId  String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([routeId])
  @@index([organizationId])
}

model DispatchDecision {
  id             String   @id @default(uuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id])
  action         String
  previousValue  String?
  newValue       String?
  reason         String?
  dispatcherId   String
  dispatcher     User     @relation(fields: [dispatcherId], references: [id])
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([invoiceId])
  @@index([organizationId])
  @@index([dispatcherId])
}

model AssignmentRecommendation {
  id                  String    @id @default(uuid())
  routeId             String
  route               Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  rank                Int
  driverId            String
  vehicleId           String
  totalDistance       Float?
  totalDuration       Int?
  totalCost           Float?
  capacityUtilization Float?
  riskScore           Float?
  score               Float?
  reason              String?
  warnings            Json?
  acceptedAt          DateTime?
  rejectedAt          DateTime?
  createdAt           DateTime  @default(now())
  organizationId      String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([routeId])
  @@index([organizationId])
  @@index([rank])
}

model VehicleCapacity {
  id                  String    @id @default(uuid())
  vehicleId           String
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maxWeight           Float?
  maxVolume           Float?
  maxItems            Int?
  maxStops            Int?
  operatingCostPerKm  Float?
  allowedZones        Json?
  roadRestriction     String?
  insuranceValidUntil DateTime?
  documentValidUntil  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  organizationId      String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([vehicleId])
  @@index([organizationId])
}

model FuelLog {
  id               String   @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId         String?
  driver           Driver?  @relation(fields: [driverId], references: [id])
  fillDate         DateTime @default(now())
  litersFilled     Float?
  costPerLiter     Float?
  totalCost        Float?
  odometer         Float
  stationName      String?
  receiptPhotoUrl  String?
  odometerPhotoUrl String?
  detectedAnomaly  Boolean  @default(false)
  anomalyReason    String?
  status           String   @default("PENDING")
  jobNumber        String?
  approvedById     String?
  approvedBy       User?    @relation("FuelLogApprover", fields: [approvedById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  organizationId   String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([vehicleId, fillDate])
}

model MaintenanceLog {
  id              String    @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
  serviceType     String
  serviceDate     DateTime  @default(now())
  cost            Float
  odometer        Float
  providerName    String?
  notes           String?
  nextDueDate     DateTime?
  nextDueOdometer Float?
  alertGenerated  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  organizationId  String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([vehicleId, serviceDate])
}

model LoadingVerification {
  id               String   @id @default(uuid())
  deliveryId       String   @unique
  delivery         Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  verifiedByUserId String
  verifiedByUser   User     @relation(fields: [verifiedByUserId], references: [id])
  materialCount    Int
  invoiceMapped    Boolean  @default(true)
  packageQuantity  Int
  truckCapacityOk  Boolean  @default(true)

  emptyTruckPhotoUrl          String?
  materialsLoadedPhotoUrl     String?
  sealedCargoPhotoUrl         String?
  invoiceVerificationPhotoUrl String?

  status             String    @default("VERIFIED")
  sealedAt           DateTime?
  driverAcknowledged Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  organizationId     String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model AnalyticsSnapshot {
  id                     String   @id @default(uuid())
  timestamp              DateTime @default(now())
  totalDeliveriesToday   Int
  trucksOnRoute          Int
  delayedDeliveries      Int
  activeDrivers          Int
  loadingInProgress      Int
  revenueToday           Float
  fuelCostToday          Float
  maintenanceAlertsCount Int
  completedDeliveries    Int
  failedDeliveries       Int
  deliverySuccessRate    Float
  organizationId         String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
}

model SystemSetting {
  id             String   @id @default(uuid())
  key            String   @unique
  value          Json
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ─── Customer Tracking & Proof of Delivery ──────────────────────────────

model DeliveryTrackingToken {
  id             String    @id @default(uuid())
  token          String    @unique
  deliveryId     String
  delivery       Delivery  @relation(fields: [deliveryId], references: [id])
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  lastAccessed   DateTime?
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([token])
  @@index([deliveryId])
  @@index([organizationId])
}

model DeliveryEvent {
  id             String   @id @default(uuid())
  deliveryId     String
  delivery       Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  type           String
  description    String?
  metadata       Json?
  latitude       Float?
  longitude      Float?
  photoUrl       String?
  signatureUrl   String?
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([deliveryId, createdAt])
  @@index([organizationId])
  @@index([type])
}

model DeliveryVoiceNote {
  id             String     @id @default(uuid())
  deliveryId     String
  delivery       Delivery   @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  driverId       String
  driver         Driver     @relation(fields: [driverId], references: [id])
  routeId        String?
  route          Route?     @relation(fields: [routeId], references: [id])
  stopId         String?
  stop           RouteStop? @relation(fields: [stopId], references: [id])
  audioUrl       String
  durationSec    Int?
  mimeType       String     @default("audio/m4a")
  createdAt      DateTime   @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([deliveryId])
  @@index([driverId])
  @@index([organizationId])
}

model DeliveryInstruction {
  id                String   @id @default(uuid())
  deliveryId        String
  delivery          Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  gateCode          String?
  buildingAccess    String?
  apartmentNumber   String?
  contactPerson     String?
  loadingNotes      String?
  preferredEntrance String?
  notes             String?
  source            String   @default("customer")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organizationId    String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([deliveryId])
  @@index([organizationId])
}

model DeliveryAvailabilityResponse {
  id             String   @id @default(uuid())
  deliveryId     String
  delivery       Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  token          String?
  customerName   String?
  customerPhone  String?
  isAvailable    Boolean
  responseTime   DateTime @default(now())
  notes          String?
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([deliveryId])
  @@index([organizationId])
}

model ProofOfDelivery {
  id             String   @id @default(uuid())
  deliveryId     String   @unique
  delivery       Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  photoUrl       String?
  signatureUrl   String?
  latitude       Float?
  longitude      Float?
  capturedAt     DateTime
  driverNote     String?
  recipientName  String?
  recipientDoc   String?
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([deliveryId])
  @@index([organizationId])
}

model DriverWorkloadMetric {
  id                  String    @id @default(uuid())
  driverId            String
  driver              Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  date                DateTime
  totalDeliveries     Int       @default(0)
  completedDeliveries Int       @default(0)
  totalWeight         Float     @default(0)
  totalVolume         Float     @default(0)
  totalDistanceKm     Float     @default(0)
  totalDurationMin    Int       @default(0)
  currentLoad         Int       @default(0)
  estimatedEndTime    DateTime?
  workloadScore       Float     @default(0)
  warnings            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  organizationId      String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([driverId, date])
  @@index([driverId])
  @@index([organizationId])
  @@index([date])
}

model RouteCluster {
  id                String   @id @default(uuid())
  name              String?
  organizationId    String
  invoiceIds        Json
  totalWeight       Float?
  totalVolume       Float?
  deliveryCount     Int?
  avgLatitude       Float?
  avgLongitude      Float?
  zone              String?
  neighborhood      String?
  citySector        String?
  priority          Int      @default(0)
  suggestedDriverId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([zone])
  @@index([neighborhood])
}

// ─── Delivery Workflow Models ──────────────────────────────────────────────

model DeliveryItem {
  id          String   @id @default(uuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  productName String
  quantity    Float?
  weight      Float?
  volume      Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([deliveryId])
  @@index([organizationId])
}

model LoadBatch {
  id                       String         @id @default(uuid())
  batchCode                String         @unique
  organizationId           String
  driverId                 String?
  driver                   Driver?        @relation(fields: [driverId], references: [id])
  vehicleId                String?
  vehicle                  Vehicle?       @relation(fields: [vehicleId], references: [id])
  dispatcherId             String?
  dispatcher               User?          @relation("LoadBatchDispatcher", fields: [dispatcherId], references: [id])
  status                   DeliveryStatus @default(CREATED)
  totalWeight              Float?
  totalVolume              Float?
  totalDeliveries          Int            @default(0)
  routeDistanceKm          Float?
  estimatedDurationMinutes Int?
  approvedAt               DateTime?
  startedAt                DateTime?
  completedAt              DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  deletedAt                DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id])
  deliveries   LoadBatchDelivery[]
  fuelRequests FuelRequest[]

  @@index([organizationId])
  @@index([driverId])
  @@index([status])
  @@index([organizationId, status])
}

model LoadBatchDelivery {
  id          String    @id @default(uuid())
  loadBatchId String
  loadBatch   LoadBatch @relation(fields: [loadBatchId], references: [id], onDelete: Cascade)
  deliveryId  String
  delivery    Delivery  @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  stopOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([loadBatchId, deliveryId])
  @@index([loadBatchId])
  @@index([deliveryId])
}

model DeliveryTimeline {
  id           String            @id @default(uuid())
  deliveryId   String
  delivery     Delivery          @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  actorId      String?
  actorRole    String?
  eventType    DeliveryEventType @default(STATUS_CHANGE)
  oldStatus    String?
  newStatus    String?
  note         String?
  latitude     Float?
  longitude    Float?
  photoUrl     String?
  signatureUrl String?
  metadata     Json?
  createdAt    DateTime          @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([deliveryId, createdAt])
  @@index([organizationId])
  @@index([eventType])
}

model FuelRequest {
  id                     String            @id @default(uuid())
  organizationId         String
  driverId               String
  driver                 Driver            @relation(fields: [driverId], references: [id])
  dispatcherId           String?
  dispatcher             User?             @relation("FuelRequestDispatcher", fields: [dispatcherId], references: [id])
  vehicleId              String
  vehicle                Vehicle           @relation(fields: [vehicleId], references: [id])
  loadBatchId            String?
  loadBatch              LoadBatch?        @relation(fields: [loadBatchId], references: [id])
  amountRequested        Float?
  fuelLiters             Float?
  fuelStation            String?
  reason                 String?
  status                 FuelRequestStatus @default(REQUESTED)
  approvedByDispatcherId String?
  approvedBy             User?             @relation("FuelRequestApprover", fields: [approvedByDispatcherId], references: [id])
  approvedAt             DateTime?
  rejectedReason         String?
  receiptPhotoUrl        String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([driverId])
  @@index([status])
  @@index([organizationId, status])
}

model Product {
  id               String   @id @default(uuid())
  name             String
  sku              String?
  category         String
  subcategory      String?
  unit             String   @default("un")
  weightPerUnit    Float?
  volumePerUnit    Float?
  unitPrice        Float?
  brand            String?
  supplier         String?
  description      String?
  certification    String?  // INMETRO, ABNT, etc.
  qualityGrade     String?  // A, B, C, etc.
  minStorageTemp   Float?
  maxStorageTemp   Float?
  shelfLifeDays    Int?
  isFragile        Boolean  @default(false)
  requiresSpecialHandling Boolean @default(false)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  organizationId   String
  deletedAt        DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([category])
  @@index([sku])
  @@unique([name, organizationId])
}

model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
